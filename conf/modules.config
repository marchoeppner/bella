process {
    
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        enabled: false,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]
    withName: REPORTREE {
        ext.args = [ 
            "--loci-called ${params.reportree_loci_called}",
            params.analysis ? "--analysis ${params.analysis}" : "--analysis grapetree",
            "--partitions2report ${params.partitions}",
            params.reportree_options ? "${params.reportree_options}" : ""
        ].join(' ').strip()
        publishDir = [
            path: { "${params.outdir}/reportree" },
            mode: params.publish_dir_mode,
            enabled: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ] 
    }
    withName: MULTIQC {
        ext.prefix = "${params.run_name}_multiqc"
    }
    withName: 'CHEWBBACA_ALLELECALL' {
        ext.args = [
            params.chewbbaca_options ? params.chewbbaca_options : "",
            params.hash_algorithm ? "--hash-profile ${params.hash_algorithm}" : ""
        ].join(" ")
        publishDir = [
            path: { "${params.outdir}/samples/${meta.sample_id}/chewbbaca" },
            mode: params.publish_dir_mode,
            enabled: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'CHEWBBACA_EXTRACTCGMLST' {
        ext.args = ""
        publishDir = [
            path: { "${params.outdir}/chewbbaca/filtered_loci" },
            mode: params.publish_dir_mode,
            enabled: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'CHEWBBACA_ALLELECALL_INSTALL' {
        ext.args = ""
        publishDir = [
            path: { "${params.reference_base}/bella/${params.reference_version}/chewbbaca" },
            mode: params.publish_dir_mode,
            enabled: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: CHEWBBACA_ALLELECALLEVALUATOR {
        publishDir = [
            path: { "${params.outdir}/samples/${meta.sample_id}/chewbbaca/" },
            mode: params.publish_dir_mode,
            enabled: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'CHEWBBACA_JOINPROFILES' {
        publishDir = [
            path: { "${params.outdir}/chewbbaca/joined" },
            mode: params.publish_dir_mode,
            enabled: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'CHEWBBACA_DOWNLOADSCHEMA|CHEWBBACA_PREPEXTERNALSCHEMA' {
       publishDir = [
            path: { "${params.reference_base}/bella/${params.reference_version}/chewbbaca" },
            mode: params.publish_dir_mode,
            enabled: false,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ] 
    }
    withName: 'SUMMARY' {
        ext.args = "--cutoff ${params.reportree_loci_called}"
        publishDir = [
            path: { "${params.outdir}/report" },
            mode: params.publish_dir_mode,
            enabled: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'REPORT' {
        ext.args = "--cutoff ${params.reportree_loci_called}"
        publishDir = [
            path: { "${params.outdir}/report" },
            mode: params.publish_dir_mode,
            enabled: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
 
    withName: 'HELPER_EXTRACT_ALLELES' {
       publishDir = [
            path: { "${params.outdir}/samples/${meta.sample_id}/chewbbaca" },
            mode: params.publish_dir_mode,
            enabled: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ] 
    }
}
